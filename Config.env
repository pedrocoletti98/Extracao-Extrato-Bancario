# Development Settings
EnvType=HML # HML = HOMOL and PRD = PROD

# Input Excel File Settings
InputExcelFileName=ContasBB.xlsx # Input Excel File Name + File Extension (Ex.: ContasBB.xlsx)
InputFolder=Input # Name of the Input folder inside the main project folder (Ex.: Input / Files\\Input)
InputExcelSheetName=INFO_CONTAS # Name of the Sheet of the Input Excel File (Ex.: INFO_CONTAS)

# Output Excel File Settings
OutputExcelFileName=extrato.xlsx # Name of the Output Excel File (Ex.: extrato.xlsx)
OutputFolder=Output # Name of the Output folder inside the main project folder (Ex.: Output / Files\\Output)
OutputLogsSheetName=Log_Execucao # Name of the Sheet used to write the Output Logs

# Homol API Settings
APIAuthTokenHomolURL=https://oauth.hm.bb.com.br/oauth/token # Url for the homol auth token API (Ex.: https://oauth.hm.bb.com.br/oauth/token)
APIExtractHomolURL=https://api.hm.bb.com.br/extratos/v1 # Url for the homol Extratos API (Ex.: https://api.hm.bb.com.br/extratos/v1)
ScopeToBeRequested=extrato-info # Scope to be requested according to the API documentation: https://apoio.developers.bb.com.br/referency/post/5f4f8169b71fb5001268c9a1  (in case of API Extratos, scope = extrato-info)
DevAppKeyHomol= # Dev APP Key available at your BB Developers Portal: https://app.developers.bb.com.br/
ClientIdHomol= # Client ID available at your BB Developers Portal: https://app.developers.bb.com.br/
ClientSecretHomol= # ClientSecret available at your BB Developers Portal: https://app.developers.bb.com.br/

# Prod API Settings
APIAuthTokenURL=https://oauth.bb.com.br/oauth/token # Url for the prod auth token API (Ex.: https://oauth.hm.bb.com.br/oauth/token)
APIExtractURL=https://api-extratos.bb.com.br/extratos/v1 # Url for the prod Extratos API (Ex.: https://api.hm.bb.com.br/extratos/v1)
DevAppKey= # Dev APP Key available at your BB Developers Portal: https://app.developers.bb.com.br/
ClientId= # Client ID available at your BB Developers Portal: https://app.developers.bb.com.br/
ClientSecret= # ClientSecret available at your BB Developers Portal: https://app.developers.bb.com.br/

# General API Settings
ExtractPageNumber=1 # Page Number that the API will return. Default is 1 (one)
ExtractMaxEntries=200 # Max acceptable Entries by API. Default is 200 (two hundred)